{
  "database": {
    "rules": "database.rules.json"
  },
  "emulators": {
    "database": { "port": 9000 },
    "ui": { "enabled": false }
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/admin", "destination": "/admin.html" },
      { "source": "/groups", "destination": "/groups.html" },
      { "source": "/", "destination": "/wheel.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(js|html|json)",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0" }]
      },
      {
        "source": "/",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0" }]
      },
      {
        "source": "/admin",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0" }]
      },
      {
        "source": "/groups",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0" }]
      }
    ]
  }
}
