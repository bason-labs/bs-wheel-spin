{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/groups", "destination": "/groups.html" },
      { "source": "/", "destination": "/wheel.html" }
    ]
  }
}
